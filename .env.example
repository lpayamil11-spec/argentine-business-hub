# Conexión a la API REST (backend crmdigital-api).
# Sin estas variables la app funciona en modo local (datos demo en localStorage).

# Activa el modo remoto: hidrata y persiste contra la API.
VITE_USE_REMOTE_API=true

# Base de la API REST.
# Producción: https://apicrmdigital.testprueba.online/api
# Local:      http://localhost:3400/api
VITE_API_BASE_URL=https://apicrmdigital.testprueba.online/api
